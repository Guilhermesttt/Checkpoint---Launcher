{
  "name": "checkpoint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "electron:dev": "node scripts/electron-dev.cjs",
    "build": "tsc -b && vite build",
    "dist": "node scripts/build-portable.cjs",
    "dist:windows": "node scripts/build-portable.cjs",
    "publish": "npm run build && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node ./server/index.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guilhermesttt/Checkpoint---Launcher.git"
  },
  "build": {
    "appId": "com.checkpoint.launcher",
    "productName": "Checkpoint Launcher",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Guilhermesttt",
      "repo": "Checkpoint---Launcher"
    },
    "files": [
      "dist/**/*",
      "src/sounds/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Checkpoint Launcher"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "@fortawesome/free-brands-svg-icons": "7.3.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@liquidglass/react": "^0.1.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "cloudscraper": "^4.6.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "discord-rpc": "^4.0.1",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "fast-average-color": "^9.5.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^14.1.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "input-otp": "^1.4.2",
    "liquid-glass-react": "^1.1.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.8.0",
    "maath": "^0.10.8",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-bits": "^1.0.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^6.26.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@eslint/js": "^9.39.4",
    "@types/discord-rpc": "^4.0.11",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "tailwind-scrollbar": "^4.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.10"
  }
}
