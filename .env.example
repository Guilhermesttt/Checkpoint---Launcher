# Frontend Firebase config. These values are public Firebase client config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional in production if frontend and backend are served by the same Express host.
VITE_BACKEND_URL=http://localhost:8787

# Backend config.
PORT=8787
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8787

# Backend-only secrets. Fill locally only in ignored env files.
STEAM_API_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
# Required for Epic library ownership sync
EPIC_SANDBOX_ID=
# Recommended for Epic token exchange/refresh used by Ecom
EPIC_DEPLOYMENT_ID=
# Optional override. By default, uses BACKEND_PUBLIC_URL + /auth/epic/callback
EPIC_REDIRECT_URI=
# Optional scopes. By default, uses basic_profile
EPIC_OAUTH_SCOPE=basic_profile
