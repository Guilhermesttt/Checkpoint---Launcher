# Frontend Firebase config. These values are public Firebase client config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# Optional in production if frontend and backend are served by the same Express host.
VITE_BACKEND_URL=http://localhost:8787

# Backend config.
PORT=8787
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8787

# Backend-only secrets. Fill locally only in ignored env files.
STEAM_API_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_DATABASE_URL=
# Optional namespace fallback for Epic catalog details.
EPIC_SANDBOX_ID=

# Discord OAuth. Optional while developing without Discord integration.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional override. By default, uses BACKEND_PUBLIC_URL + /auth/discord/callback
DISCORD_REDIRECT_URI=
# Minimum: identify. To import Discord friend list, use: identify relationships.read
# Discord may require approval/availability for relationships.read.
DISCORD_OAUTH_SCOPE=identify

# Discord Rich Presence Application ID
# Create an application at https://discord.com/developers/applications
# Copy the Application ID here
VITE_DISCORD_APPLICATION_ID=

# Google OAuth desktop/browser login. Keep the secret only in ignored env files.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. By default, uses BACKEND_PUBLIC_URL + /auth/google/callback
GOOGLE_REDIRECT_URI=
