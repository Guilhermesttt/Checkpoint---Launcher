rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function validProfileCreate(userId) {
      return isSignedInOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validProfileUpdate(userId) {
      return isSignedInOwner(userId)
        && request.resource.data.uid == userId;
    }

    match /profiles/{userId} {
      allow create: if validProfileCreate(userId);
      allow read: if isSignedIn();
      allow update: if validProfileUpdate(userId);
      allow delete: if false;
    }

    match /users/{userId} {
      allow create, read, update: if isSignedInOwner(userId);
      allow delete: if false;

      match /games/{gameId} {
        allow read, write: if isSignedInOwner(userId);
      }
    }

    match /messages/{messageId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'chatId',
          'senderId',
          'receiverId',
          'text',
          'createdAt',
          'read',
          'attachmentName',
          'attachmentUrl',
          'attachmentType',
          'attachmentSize',
          'attachmentPath'
        ])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.chatId is string
        && request.resource.data.text is string
        && (
          request.resource.data.text.size() > 0
          || request.resource.data.attachmentUrl.size() > 0
        )
        && request.resource.data.text.size() <= 2000
        && request.resource.data.attachmentName is string
        && request.resource.data.attachmentUrl is string
        && request.resource.data.attachmentType is string
        && request.resource.data.attachmentPath is string
        && request.resource.data.attachmentSize is number
        && request.resource.data.read == false;

      allow read: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);

      allow update: if isSignedIn()
        && resource.data.receiverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read is bool;

      allow delete: if false;
    }

    match /chatTyping/{typingId} {
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'chatId',
          'userId',
          'participants',
          'typing',
          'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.chatId is string
        && request.resource.data.typing is bool
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll([request.auth.uid]);

      allow read: if isSignedIn()
        && resource.data.participants is list
        && resource.data.participants.hasAll([request.auth.uid]);

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
