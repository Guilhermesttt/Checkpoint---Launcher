rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function validEditableProfileFields() {
      let data = request.resource.data;
      return (!('displayName' in data)
          || (data.displayName is string
            && data.displayName.size() >= 2
            && data.displayName.size() <= 50))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 280))
        && (!('location' in data) || (data.location is string && data.location.size() <= 80))
        && (!('pronouns' in data) || (data.pronouns is string && data.pronouns.size() <= 40))
        && (!('website' in data)
          || (data.website is string
            && data.website.size() <= 300
            && (data.website == '' || data.website.matches('^https://.*$'))))
        && (!('favoriteGenres' in data)
          || (data.favoriteGenres is list && data.favoriteGenres.size() <= 6));
    }

    function validProfileCreate(userId) {
      return isSignedInOwner(userId)
        && request.resource.data.uid == userId
        && validEditableProfileFields()
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'bio',
          'location',
          'pronouns',
          'website',
          'favoriteGenres',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validProfileUpdate(userId) {
      return isSignedInOwner(userId)
        && request.resource.data.uid == userId
        && validEditableProfileFields()
        && request.resource.data.createdAt == resource.data.createdAt
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'checkpointFriends',
          'checkpointFriendRequestsIncoming',
          'checkpointFriendRequestsOutgoing'
        ])
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'bio',
          'location',
          'pronouns',
          'website',
          'favoriteGenres',
          'createdAt',
          'updatedAt',
          'steamId',
          'steamUsername',
          'steamAvatar',
          'discordId',
          'discordUsername',
          'discordAvatar',
          'discordFriends',
          'checkpointFriends',
          'checkpointFriendRequestsIncoming',
          'checkpointFriendRequestsOutgoing',
          'presence',
          'status',
          'playing',
          'lastSteamSyncAt',
          'gamesMigratedAt',
          'migrationSkippedReason',
          'onboardingCompletedAt',
          'achievementSummary',
          'steamAchievementSync'
        ]);
    }

    match /profiles/{userId} {
      allow create: if validProfileCreate(userId);
      allow read: if isSignedIn();
      allow update: if validProfileUpdate(userId);
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedInOwner(userId)
        && request.resource.data.uid == userId
        && validEditableProfileFields()
        && request.resource.data.keys().hasOnly([
          'schemaVersion',
          'uid',
          'displayName',
          'photoURL',
          'bio',
          'location',
          'pronouns',
          'website',
          'favoriteGenres',
          'stats',
          'platforms',
          'achievements',
          'topGames',
          'favoriteGames',
          'revision',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId} {
      allow create, read, update: if isSignedInOwner(userId);
      allow delete: if false;

      match /games/{gameId} {
        allow read, write: if isSignedInOwner(userId);
      }
    }

    match /activities/{activityId} {
      // Colecao canonica usada apenas pelo backend para deduplicacao e auditoria.
      allow read, write: if false;
    }

    match /feeds/{userId}/activities/{activityId} {
      // Cada consulta fica presa ao UID do caminho, algo que o Firestore
      // consegue validar antes de executar a query.
      allow read: if isSignedInOwner(userId);
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
